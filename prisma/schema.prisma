// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BoardMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  image     String
  github    String?
  linkedin  String?
  discord   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Advisory {
  id        String   @id @default(cuid())
  name      String
  role      String
  image     String
  github    String?
  linkedin  String?
  discord   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String
  date        String
  location    String
  time        String
  image       String
  tags        String[]
  status      EventStatus @default(UPCOMING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum EventStatus {
  LIVE
  UPCOMING
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
